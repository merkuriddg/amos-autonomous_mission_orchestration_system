# AMOS Edition Configuration
# ──────────────────────────
# "open"       — Open-core C2 platform (default)
# "enterprise" — Full platform with all commercial modules
AMOS_EDITION=open

# Environment & Dev Tools
# ───────────────────────
# AMOS_ENV: "dev" enables developer tools (system scripts UI)
AMOS_ENV=dev
# AMOS_ALLOW_GIT_UI: enable git operations UI even outside dev env
AMOS_ALLOW_GIT_UI=true

# Per-feature overrides (enterprise only, all default to "true")
# Set any to "false" to disable a specific module:
# AMOS_ENABLE_COGNITIVE=true
# AMOS_ENABLE_NLP=true
# AMOS_ENABLE_COA=true
# AMOS_ENABLE_COMMANDER=true
# AMOS_ENABLE_LEARNING=true
# AMOS_ENABLE_HAL=true
# AMOS_ENABLE_PREDICTIONS=true
# AMOS_ENABLE_WARGAME=true
# AMOS_ENABLE_REDFORCE=true
# AMOS_ENABLE_DOCS_GEN=true
# AMOS_ENABLE_SWARM=true
# AMOS_ENABLE_COMSEC=true
# AMOS_ENABLE_SECURITY=true
# AMOS_ENABLE_TAK=true
# AMOS_ENABLE_LINK16=true
# AMOS_ENABLE_VMF=true
# AMOS_ENABLE_STANAG=true
# AMOS_ENABLE_NFFI=true
# AMOS_ENABLE_OGC=true
# AMOS_ENABLE_KAFKA=true
# AMOS_ENABLE_EFFECTS=true
# AMOS_ENABLE_ISR=true
# AMOS_ENABLE_SPACE=true
# AMOS_ENABLE_HMT=true
# AMOS_ENABLE_KILLWEB=true
# AMOS_ENABLE_CONTESTED=true

# Database (MariaDB — optional, AMOS runs without it)
# ────────────────────────────────────────────────────
# Run  bash db/setup.sh  to auto-generate these values.
# AMOS_DB_USER=amos
# AMOS_DB_PASS=
# AMOS_DB_NAME=amos
# AMOS_DB_SOCKET=/tmp/mysql.sock
