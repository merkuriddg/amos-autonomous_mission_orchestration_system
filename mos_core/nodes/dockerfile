# MOS — Mission Operating System
# Production Container

FROM python:3.11-slim

LABEL maintainer="Mavrix Defense Systems"
LABEL description="MOS - Mission Operating System"

WORKDIR /opt/mos

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl net-tools && \
    rm -rf /var/lib/apt/lists/*

# Python deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application
COPY mos_core/ ./mos_core/
COPY web/ ./web/
COPY config/ ./config/
COPY scripts/ ./scripts/

# Environment
ENV FLASK_SECRET_KEY=mos-production-key-change-me
ENV PYTHONUNBUFFERED=1

EXPOSE 5000
HEALTHCHECK --interval=30s --timeout=5s CMD curl -f http://localhost:5000/login || exit 1

CMD ["python3", "web/app.py"]
