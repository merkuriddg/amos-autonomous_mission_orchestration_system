@app.route("/api/aar/events")
@login_required
def api_aar_events():
    return jsonify(aar_events[-200:])

@app.route("/api/aar/export")
@login_required
def api_aar_export():
    return jsonify({
        "mission": "Tampa Bay Interdiction",
        "exported": datetime.now(timezone.utc).isoformat(),
        "duration_sec": sim_clock["elapsed_sec"],
        "events": aar_events,
        "countermeasures": countermeasure_log,
        "hal_actions": hal_log,
        "threats": sim_threats,
        "asset_count": len(registry.assets),
    })

# ════════════════════════════════════════════
#  API — SIM CONTROL
# ════════════════════════════════════════════

@app.route("/api/sim/status")
@login_required
def api_sim_status():
    return jsonify({
        "running": sim_running,
        "clock": sim_clock,
        "assets": len(registry.assets),
        "active_threats": sum(1 for t in sim_threats.values()
                             if not t.get("neutralized")),
        "neutralized": sum(1 for t in sim_threats.values()
                          if t.get("neutralized")),
    })

@app.route("/api/sim/speed", methods=["POST"])
@login_required
def api_sim_speed():
    data = request.get_json(force=True)
    sim_clock["speed"] = max(0.1, min(10, data.get("speed", 1.0)))
    return jsonify({"speed": sim_clock["speed"]})

# ════════════════════════════════════════════
#  API — COMMS MESH
# ════════════════════════════════════════════

@app.route("/api/comms/mesh")
@login_required
def api_comms_mesh():
    return jsonify(comms_mesh[:100])

