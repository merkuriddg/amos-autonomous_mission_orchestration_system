@app.route("/api/cyber/block", methods=["POST"])
@login_required
def api_cyber_block():
    data = request.get_json(force=True)
    if "ip" in data:
        return jsonify(cyber.block_ip(data["ip"], data.get("reason", "")))
    elif "event_id" in data:
        return jsonify(cyber.block_event(data["event_id"]))
    return jsonify({"error": "Provide ip or event_id"})

# ════════════════════════════════════════════
#  API — COUNTERMEASURES
# ════════════════════════════════════════════

@app.route("/api/cm/engage", methods=["POST"])
@login_required
def api_cm_engage():
    data = request.get_json(force=True)
    threat_id = data.get("threat_id")
    cm_type = data.get("type", "jam")  # jam | intercept | cyber_block
    if threat_id and threat_id in sim_threats:
        sim_threats[threat_id]["neutralized"] = True
        sim_threats[threat_id]["status"] = f"neutralized_{cm_type}"
        entry = {
            "threat_id": threat_id, "type": cm_type,
            "operator": session.get("name", "unknown"),
            "timestamp": datetime.now(timezone.utc).isoformat(),
        }
        countermeasure_log.append(entry)
        aar_events.append({
            "timestamp": entry["timestamp"],
            "elapsed": sim_clock["elapsed_sec"],
            "type": "countermeasure",
            "details": f"{cm_type.upper()} on {threat_id} by {entry['operator']}",
        })
        return jsonify({"success": True, "action": entry})
    return jsonify({"success": False, "error": "Threat not found"})

@app.route("/api/cm/log")
@login_required
def api_cm_log():
    return jsonify(countermeasure_log)

# ════════════════════════════════════════════
#  API — HAL (Autonomy Recommendations)
# ════════════════════════════════════════════

@app.route("/api/hal/recommendations")
@login_required
def api_hal_recs():
    return jsonify(hal_recommendations)

@app.route("/api/hal/action", methods=["POST"])
@login_required
def api_hal_action():
    data = request.get_json(force=True)
    rec_id = data.get("id")
    action = data.get("action")  # approve | deny
    for rec in hal_recommendations:
        if rec["id"] == rec_id:
            rec["status"] = "approved" if action == "approve" else "denied"
            rec["actioned_by"] = session.get("name")
            rec["actioned_at"] = datetime.now(timezone.utc).isoformat()
            hal_log.append(rec)
            return jsonify({"success": True, "recommendation": rec})
    return jsonify({"success": False, "error": "Not found"})

