#!/usr/bin/env python3
"""
MOS — Mission Orchestration System
Main Web Application / C2 Console
All phases integrated.
"""

import os
import sys
import json
import time
import random
import math
import threading
import yaml
from pathlib import Path
from datetime import datetime, timezone, timedelta
from functools import wraps

from flask import (Flask, render_template, jsonify, request,
                   redirect, url_for, session)
from flask_socketio import SocketIO

# ── Add project root to path ──
ROOT = Path(__file__).parent.parent
sys.path.insert(0, str(ROOT))

# ── Import MOS Core Nodes ──
from mos_core.nodes.asset_registry import AssetRegistry
from mos_core.nodes.autonomy_manager import AutonomyManager
from mos_core.nodes.swarm_orchestrator import SwarmOrchestrator
from mos_core.nodes.threat_detector import ThreatDetector
from mos_core.nodes.sensor_fusion import SensorFusion
from mos_core.nodes.coa_engine import COAEngine
from mos_core.nodes.geofence_manager import GeofenceManager
from mos_core.nodes.atak_bridge import ATAKBridge
from mos_core.nodes.ew_manager import EWManager
from mos_core.nodes.sigint_collector import SIGINTCollector
from mos_core.nodes.cyber_ops import CyberOps

# ════════════════════════════════════════════
#  FLASK APP SETUP
# ════════════════════════════════════════════

app = Flask(__name__,
            template_folder=str(ROOT / "web" / "templates"),
            static_folder=str(ROOT / "web" / "static"))
app.secret_key = os.environ.get("FLASK_SECRET_KEY", "mos-dev-key-2026")
socketio = SocketIO(app, cors_allowed_origins="*", async_mode="threading")

# ════════════════════════════════════════════
#  INITIALIZE ALL MOS NODES
# ════════════════════════════════════════════

config_path = ROOT / "config" / "platoon_config.yaml"
registry = AssetRegistry(config_path)
autonomy = AutonomyManager()
swarm = SwarmOrchestrator()
threat_detector = ThreatDetector()
sensor_fusion = SensorFusion()
coa_engine = COAEngine()
geofence = GeofenceManager()
ew_manager = EWManager()
sigint = SIGINTCollector()
cyber = CyberOps()

# Set autonomy tiers from config
for asset_id, asset in registry.assets.items():
    autonomy.set_tier(asset_id, asset.get("autonomy_tier", 1), "Initial config")

# Register EW-capable assets
for asset_id, asset in registry.assets.items():
    sensors = asset.get("sensors", [])
    if "EW_JAMMER" in sensors or "SIGINT" in sensors or "ELINT" in sensors:
        ew_manager.register_ew_asset(asset_id, {"sensors": sensors})

# Default geofences
geofence.add_zone("AO-TAMPA", "inclusion", [
    {"lat": 28.10, "lng": -82.80}, {"lat": 28.10, "lng": -82.20},
    {"lat": 27.60, "lng": -82.20}, {"lat": 27.60, "lng": -82.80},
], floor_ft=0, ceiling_ft=40000)
geofence.add_zone("TPA-AIRPORT", "exclusion", [
    {"lat": 27.985, "lng": -82.545}, {"lat": 27.985, "lng": -82.520},
    {"lat": 27.960, "lng": -82.520}, {"lat": 27.960, "lng": -82.545},
], floor_ft=0, ceiling_ft=18000)

# Load threats from config
threat_config = yaml.safe_load(open(config_path)) if config_path.exists() else {}
sim_threats = {}
for t in threat_config.get("threats", []):
    t["status"] = "active"
    t["neutralized"] = False
    sim_threats[t["id"]] = t
    if t["type"] in ("drone", "vessel", "rf_emitter", "gps_jammer"):
        threat_detector.ingest(t)

print(f"\n[MOS] ═══════════════════════════════════════")
print(f"[MOS]  Loaded {len(registry.assets)} assets")
print(f"[MOS]  Loaded {len(sim_threats)} threats")
print(f"[MOS]  EW assets: {len(ew_manager.ew_assets)}")
print(f"[MOS]  Geofences: {len(geofence.zones)}")
print(f"[MOS] ═══════════════════════════════════════\n")

# ════════════════════════════════════════════
#  AUTH / RBAC
# ════════════════════════════════════════════

USERS = {
    "commander":  {"password": "mavrix2026", "role": "commander",  "name": "CDR Williams"},
    "ewoff":      {"password": "spectrum1", "role": "ew_officer", "name": "EW Officer Chen"},
    "cyber":      {"password": "defend01",  "role": "cyber_op",   "name": "Cyber Op Rivera"},
    "pilot":      {"password": "wings01",   "role": "pilot",      "name": "Pilot Kowalski"},
    "analyst":    {"password": "intel01",   "role": "analyst",    "name": "Analyst Park"},
    "observer":   {"password": "watch01",   "role": "observer",   "name": "Observer Davis"},
}

ROLE_ACCESS = {
    "commander":  ["all"],
    "ew_officer": ["/", "/ew", "/sigint", "/countermeasures"],
    "cyber_op":   ["/", "/cyber", "/countermeasures"],
    "pilot":      ["/", "/planner", "/field", "/dashboard"],
    "analyst":    ["/", "/sigint", "/aar", "/dashboard"],
    "observer":   ["/", "/field", "/dashboard"],
}

def login_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        if "user" not in session:
            return redirect(url_for("login"))
        return f(*args, **kwargs)
    return decorated

def check_access(route):
    if "user" not in session:
        return False
    role = session.get("role", "observer")
    allowed = ROLE_ACCESS.get(role, [])
    return "all" in allowed or route in allowed

# ════════════════════════════════════════════
#  SIMULATION ENGINE
# ════════════════════════════════════════════

sim_running = True
sim_clock = {"elapsed_sec": 0, "speed": 1.0}
countermeasure_log = []
hal_recommendations = []
hal_log = []
aar_events = []
missions = []
comms_mesh = []

def sim_tick():
    """Main simulation loop — moves assets, threats, generates events."""
    while sim_running:
        dt = 1.0 * sim_clock["speed"]
        sim_clock["elapsed_sec"] += dt
        now_str = datetime.now(timezone.utc).isoformat()

        # ── Move friendly assets along patrol routes ──
        for aid, asset in registry.assets.items():
            pos = asset["position"]
            domain = asset["domain"]
            status = asset["status"]

            if status == "standby":
                asset["status"] = "active"

            # Gentle patrol movement
            drift_lat = random.uniform(-0.0003, 0.0003) * dt
            drift_lng = random.uniform(-0.0003, 0.0003) * dt
            pos["lat"] = round(pos["lat"] + drift_lat, 6)
            pos["lng"] = round(pos["lng"] + drift_lng, 6)
            asset["heading"] = round(random.uniform(0, 360), 1)

            if domain == "air":
                asset["speed_kts"] = round(random.uniform(80, 200) if "MQ-9B" in asset["type"]
                                           else random.uniform(30, 80), 1)
            elif domain == "ground":
                asset["speed_kts"] = round(random.uniform(5, 25), 1)
            elif domain == "maritime":
                asset["speed_kts"] = round(random.uniform(8, 30), 1)

            # Battery/fuel drain
            h = asset["health"]
            drain = 0.002 * dt
            if domain == "air":
                drain = 0.005 * dt
            h["battery_pct"] = round(max(5, h["battery_pct"] - drain), 1)
            h["comms_strength"] = round(min(100, max(40,
                h["comms_strength"] + random.uniform(-2, 2))), 1)
            asset["last_update"] = now_str

            # Feed sensor fusion
            for sensor in asset.get("sensors", [])[:1]:
                sensor_fusion.ingest({
                    "sensor_type": sensor, "sensor_id": aid,
                    "lat": pos["lat"], "lng": pos["lng"],
                    "confidence": random.uniform(0.6, 0.95),
                    "classification": "FRIENDLY",
                })

        # ── Move threats ──
        for tid, threat in sim_threats.items():
            if threat.get("neutralized"):
                continue
            # Skip threats without geographic position (cyber threats)
            if "lat" not in threat or "lng" not in threat:
                continue
            speed_factor = threat.get("speed_kts", 20) * 0.00001 * dt
            threat["lat"] = round(threat["lat"] + random.uniform(-speed_factor, speed_factor), 6)
            threat["lng"] = round(threat["lng"] + random.uniform(-speed_factor, speed_factor), 6)

            # Re-ingest for threat tracking
            threat_detector.ingest(threat)

        # ── Generate SIGINT intercepts ──
        if random.random() < 0.3:
            collectors = ["SPECTR-01", "SPECTR-02", "REAPER-01", "AWACS-01"]
            freqs = [433.0, 915.0, 1575.42, 2437.0, 5805.0, 146.52, 462.5]
            sigint.add_intercept({
                "collector": random.choice(collectors),
                "freq_mhz": random.choice(freqs) + random.uniform(-0.5, 0.5),
                "power_dbm": round(random.uniform(-80, 10), 1),
                "modulation": random.choice(["FM", "AM", "OFDM", "FHSS", "DSSS", "CW"]),
                "classification": random.choice(["HOSTILE", "SUSPECT", "UNKNOWN", "CIVILIAN"]),
                "bearing_deg": round(random.uniform(0, 360), 1),
            })

        # ── Generate cyber events ──
        if random.random() < 0.15:
            severities = ["low", "medium", "high", "critical"]
            weights = [0.4, 0.3, 0.2, 0.1]
            sev = random.choices(severities, weights=weights)[0]
            event_types = ["port_scan", "brute_force", "malware_beacon",
                          "data_exfil", "dns_tunnel", "arp_spoof",
                          "unauthorized_access", "packet_injection"]
            cyber.ingest_event({
                "type": random.choice(event_types),
                "severity": sev,
                "source_ip": f"10.{random.randint(1,254)}.{random.randint(1,254)}.{random.randint(1,254)}",
                "target": random.choice(["mos-c2", "mesh-node-01", "gcs-link",
                                         "sat-uplink", "atak-server"]),
                "details": f"Auto-detected at {now_str}",
            })

        # ── HAL recommendations ──
        if random.random() < 0.1 and len(hal_recommendations) < 20:
            hostile_tracks = threat_detector.get_hostile_tracks()
            if hostile_tracks:
                target = random.choice(hostile_tracks)
                available = [a for a in registry.assets.values()
                            if a["status"] == "active"
                            and a["domain"] == "air"]
                if available:
                    asset = random.choice(available)
                    rec = {
                        "id": f"HAL-{random.randint(1000,9999)}",
                        "type": random.choice(["INTERCEPT", "JAM", "INVESTIGATE", "REPOSITION"]),
                        "asset": asset["id"],
                        "target": target.get("track_id", target.get("id", "?")),
                        "confidence": round(random.uniform(0.7, 0.95), 2),
                        "reasoning": f"Hostile track within {target.get('distance_nm', '?')}nm, "
                                    f"asset {asset['id']} is nearest capable responder.",
                        "status": "pending",
                        "timestamp": now_str,
                    }
                    hal_recommendations.append(rec)

        # ── AAR event logging ──
        if random.random() < 0.2:
            aar_events.append({
                "timestamp": now_str,
                "elapsed": sim_clock["elapsed_sec"],
                "type": random.choice(["detection", "maneuver", "ew_action",
                                       "comms_event", "status_change"]),
                "details": f"Sim event at T+{int(sim_clock['elapsed_sec'])}s",
            })
            if len(aar_events) > 2000:
                del aar_events[:-2000]

        # ── Comms mesh simulation ──
        comms_mesh.clear()
        asset_list = list(registry.assets.values())
        for i, a in enumerate(asset_list):
            for b in asset_list[i+1:]:
                dist = math.sqrt((a["position"]["lat"] - b["position"]["lat"])**2 +
                                (a["position"]["lng"] - b["position"]["lng"])**2)
                if dist < 0.05:  # ~5km
                    comms_mesh.append({
                        "from": a["id"], "to": b["id"],
                        "strength": round(max(0, 100 - dist * 2000), 1),
                        "type": "mesh",
                    })

        # ── Push to all connected clients ──
        try:
            socketio.emit("sim_update", {
                "clock": sim_clock,
                "asset_count": len(registry.assets),
                "threat_count": sum(1 for t in sim_threats.values()
                                   if not t.get("neutralized")),
                "hostile_tracks": len(threat_detector.get_hostile_tracks()),
                "pending_hal": sum(1 for r in hal_recommendations
                                  if r["status"] == "pending"),
                "cyber_active": cyber.summary().get("active_threats", 0),
                "timestamp": now_str,
            })
        except Exception:
            pass

        time.sleep(1.0 / max(0.1, sim_clock["speed"]))


# Start sim in background
sim_thread = threading.Thread(target=sim_tick, daemon=True)
sim_thread.start()
print("[MOS] Simulation engine started")

# ════════════════════════════════════════════
