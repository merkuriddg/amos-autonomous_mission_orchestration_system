@app.route("/api/coa/generate", methods=["POST"])
@login_required
def api_coa_generate():
    threats_list = [t for t in sim_threats.values() if not t.get("neutralized")]
    assets_list = []
    for a in registry.assets.values():
        flat = dict(a)
        flat["lat"] = a["position"]["lat"]
        flat["lng"] = a["position"]["lng"]
        assets_list.append(flat)
    coas = coa_engine.generate(threats_list, assets_list)
    return jsonify(coas)

